/-
# Hurewicz Theorem (L4)
-/

import MiniHomotopyTheory.Core.Basic
import MiniHomotopyTheory.Groups.FundamentalGroup

namespace MiniHomotopyTheory

def firstHomologyRank (X : TwoComplex) : Nat :=
  if X.numEdges >= X.numVertices then X.numEdges - X.numVertices + 1 else 0

def hurewiczCheck (X : TwoComplex) (maxLen : Nat) : Bool :=
  let pi1Rank := (X.fundamentalGroupApprox 0 maxLen).length
  let h1Rank := firstHomologyRank X
  pi1Rank >= h1Rank

#eval hurewiczCheck S1 6
#eval hurewiczCheck T2 5

def abelianization (X : TwoComplex) (maxLen : Nat) : Nat :=
  let pi1 := X.fundamentalGroupApprox 0 maxLen
  pi1.length

def hurewiczMap (X : TwoComplex) (maxLen : Nat) : List (List EdgeStep) :=
  X.fundamentalGroupApprox 0 maxLen

def secondHomologyRank (X : TwoComplex) : Nat :=
  X.numFaces

def hurewiczTable : List (String × Nat × Nat) :=
  let spaces : List (String × TwoComplex) :=
    [("S1", S1), ("S2", S2), ("T2", T2), ("RP2", RP2),
     ("Klein", KleinBottle), ("Fig8", FigureEight),
     ("M(Z/2)", mooreSpaceZmod 2), ("M(Z/3)", mooreSpaceZmod 3)]
  spaces.map fun (name, X) =>
    let h1 := firstHomologyRank X
    let pi1Ab := abelianization X 6
    (name, h1, pi1Ab)

def hurewiczIsomorphismCheck (X : TwoComplex) (maxLen : Nat) : Bool :=
  let h1 := firstHomologyRank X
  let pi1AbRank := abelianization X maxLen
  h1 <= pi1AbRank

def homologyEstimate (X : TwoComplex) : (Nat × Nat × Nat) :=
  (X.numVertices, X.numEdges, X.numFaces)

def cellularBoundaryMatrix (X : TwoComplex) : List (List Int) :=
  X.faces.map fun face =>
    X.edges.map fun edge => 0

def firstHomologyGroupOrder (X : TwoComplex) (maxLen : Nat) : Nat :=
  firstHomologyRank X

def hurewiczForSpheres : List (Nat × String) :=
  [(1, "Z"), (2, "0"), (3, "0"), (4, "0")]

def hurewiczForProjectiveSpaces : List (Nat × String) :=
  [(1, "Z/2Z"), (2, "Z/2Z"), (3, "0")]

#eval "=== Hurewicz Theorem Checks ==="
#eval hurewiczTable
#eval hurewiczCheck T2 5
#eval hurewiczCheck RP2 6
#eval hurewiczCheck KleinBottle 5
#eval hurewiczCheck FigureEight 5
#eval hurewiczCheck (mooreSpaceZmod 2) 8
#eval hurewiczCheck (mooreSpaceZmod 3) 8
#eval hurewiczCheck (mooreSpaceZmod 5) 8
#eval "Homology estimates:"
#eval ("S1 H1:", firstHomologyRank S1)
#eval ("T2 H1:", firstHomologyRank T2)
#eval ("RP2 H1:", firstHomologyRank RP2)


end MiniHomotopyTheory

