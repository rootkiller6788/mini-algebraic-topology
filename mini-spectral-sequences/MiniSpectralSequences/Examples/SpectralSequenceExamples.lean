/-- The Atiyah-Hirzebruch SS for K-theory of a point:
    E_2^{p,q} = H^p(pt; K^q(pt)). Only q even are non-zero.
    The SS collapses, giving K^*(pt). -/
structure KTheoryPoint where
  K0 : String := "K^0(pt) = Z"
  K1 : String := "K^1(pt) = 0"
  Bott_periodicity : String := "K^n+2(pt) ‚ČÖ K^n(pt)"

/-- The Atiyah-Hirzebruch SS for K-theory of CP^n.
    E_2^{p,q} = H^p(CP^n; K^q(pt)).
    All differentials vanish (even cohomology). -/
structure KTheoryCPn_Computation where
